# Reverse proxy with automatic TLS (Let's Encrypt), single origin.
# The address comes EXCLUSIVELY from the environment (.env):
#   SITE_ADDRESS=":80"            -> local / behind your own proxy, no TLS
#   SITE_ADDRESS="jobs.example.com" -> public domain, auto-TLS via Let's Encrypt
{$SITE_ADDRESS::80} {
	encode gzip

	# Uploads (CV, certificates) up to 30 MB
	request_body {
		max_size 30MB
	}

	# API & tooling -> Spring Boot backend (load-balanced with --scale backend=N)
	@backend path /api/* /actuator/* /v3/api-docs* /swagger-ui* /swagger-ui.html
	handle @backend {
		reverse_proxy backend:8080 {
			lb_policy round_robin
			fail_duration 5s
		}
	}

	# Everything else -> SvelteKit frontend
	handle {
		reverse_proxy frontend:3000
	}
}
