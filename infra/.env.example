# Kopiere diese Datei nach .env und passe die Werte an.
# WICHTIG: In Produktion echte Secrets über Infisical / sichere ENV-Verwaltung setzen.

# --- Datenbank ---
DB_PASSWORD=bewerbungsatze

# --- Auth / Krypto (Base64, 32 Byte). Mit `openssl rand -base64 32` erzeugen ---
JWT_SECRET=Y2hhbmdlLW1lLXRoaXMtaXMtYS1kZXYtb25seS1zZWNyZXQtMzJieXRlcyE=
CRYPTO_MASTER_KEY=ZGV2LW9ubHktbWFzdGVyLWtleS0zMi1ieXRlcy1vayE=

# --- Storage ---
STORAGE_BACKEND=minio
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# --- Embeddings ---
# Vektor-Dimension des Embedding-Modells. NUR vor dem ersten DB-Start setzbar
# (legt die pgvector-Spalten an). Beispiele: 768 (Ollama nomic-embed-text),
# 1536 (OpenAI text-embedding-3-small), 1024 (Cohere/Mistral).
EMBEDDING_DIM=768

# --- Frontend CORS ---
CORS_ORIGINS=http://localhost:5173

# --- Infisical (Machine Identity) ---
INFISICAL_ENABLED=false
INFISICAL_URL=https://app.infisical.com
INFISICAL_CLIENT_ID=
INFISICAL_CLIENT_SECRET=
INFISICAL_PROJECT_ID=
INFISICAL_ENV=prod

# --- Produktion (docker-compose.prod.yml) ---
# Öffentliche Adresse des Caddy-Reverse-Proxy. KEINE Domain im Repo hardcoden –
# jede Installation setzt hier ihre eigene:
#   SITE_ADDRESS=:80              -> lokal / hinter eigenem Proxy, ohne TLS
#   SITE_ADDRESS=jobs.example.com -> eigene Domain, automatisches TLS (Let's Encrypt)
SITE_ADDRESS=:80
# Öffentliche Origin für CORS – muss zur SITE_ADDRESS passen,
# z. B. https://jobs.example.com (bzw. http://localhost bei :80).
PUBLIC_ORIGIN=http://localhost
# Welcher Image-Tag aus der Registry gezogen wird (latest, v1.0.0, <sha> …).
IMAGE_TAG=latest
# Image-Koordinaten (Default: offizielle GHCR-Images dieses Repos; bei Forks anpassen).
# BACKEND_IMAGE=ghcr.io/<owner>/bewerbungsatze-backend
# FRONTEND_IMAGE=ghcr.io/<owner>/bewerbungsatze-frontend
# Host-Ports des Reverse-Proxy.
HTTP_PORT=80
HTTPS_PORT=443
