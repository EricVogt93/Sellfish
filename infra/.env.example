# Kopiere diese Datei nach .env und passe die Werte an.
# WICHTIG: In Produktion echte Secrets über Infisical / sichere ENV-Verwaltung setzen.

# --- Datenbank ---
DB_PASSWORD=bewerbungsatze

# --- Auth / Krypto (Base64, 32 Byte). Mit `openssl rand -base64 32` erzeugen ---
JWT_SECRET=Y2hhbmdlLW1lLXRoaXMtaXMtYS1kZXYtb25seS1zZWNyZXQtMzJieXRlcyE=
CRYPTO_MASTER_KEY=ZGV2LW9ubHktbWFzdGVyLWtleS0zMmJ5dGVzLWxvbmchISE=

# --- Storage ---
STORAGE_BACKEND=minio
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# --- Frontend CORS ---
CORS_ORIGINS=http://localhost:5173

# --- Infisical (Machine Identity) ---
INFISICAL_ENABLED=false
INFISICAL_URL=https://app.infisical.com
INFISICAL_CLIENT_ID=
INFISICAL_CLIENT_SECRET=
INFISICAL_PROJECT_ID=
INFISICAL_ENV=prod

# --- Produktion (docker-compose.prod.yml) ---
# Öffentliche Origin (für CORS); bei Reverse-Proxy die echte Domain eintragen.
PUBLIC_ORIGIN=http://localhost
# Welcher Image-Tag aus GHCR gezogen wird (latest, v1.0.0, <sha> …).
IMAGE_TAG=latest
# Optionale Image-Overrides (Default: ghcr.io/<owner>/bewerbungsatze-{backend,frontend}).
# BACKEND_IMAGE=ghcr.io/ericvogt93/bewerbungsatze-backend
# FRONTEND_IMAGE=ghcr.io/ericvogt93/bewerbungsatze-frontend
# Host-Port des nginx-Reverse-Proxy.
HTTP_PORT=80
