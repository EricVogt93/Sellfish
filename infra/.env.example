# Copy this file to .env and adjust the values.
# IMPORTANT: In production, set real secrets via Infisical or a secure env manager.

# --- Database ---
DB_PASSWORD=bewerbungsatze

# --- Auth / Crypto (Base64, 32 bytes). Generate with `openssl rand -base64 32` ---
JWT_SECRET=Y2hhbmdlLW1lLXRoaXMtaXMtYS1kZXYtb25seS1zZWNyZXQtMzJieXRlcyE=
CRYPTO_MASTER_KEY=ZGV2LW9ubHktbWFzdGVyLWtleS0zMi1ieXRlcy1vayE=

# --- Storage ---
STORAGE_BACKEND=minio
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# --- Embeddings ---
# Vector dimension of the embedding model. Settable ONLY before the first DB start
# (creates the pgvector columns). Examples: 768 (Ollama nomic-embed-text),
# 1536 (OpenAI text-embedding-3-small), 1024 (Cohere/Mistral).
EMBEDDING_DIM=768

# --- Frontend CORS ---
CORS_ORIGINS=http://localhost:5173

# --- Infisical (Machine Identity) ---
INFISICAL_ENABLED=false
INFISICAL_URL=https://app.infisical.com
INFISICAL_CLIENT_ID=
INFISICAL_CLIENT_SECRET=
INFISICAL_PROJECT_ID=
INFISICAL_ENV=prod

# --- Production (docker-compose.prod.yml) ---
# Public address of the Caddy reverse proxy. NO domain is hardcoded in the repo —
# each installation sets its own:
#   SITE_ADDRESS=:80              -> local / behind your own proxy, no TLS
#   SITE_ADDRESS=jobs.example.com -> your own domain, automatic TLS (Let's Encrypt)
SITE_ADDRESS=:80
# Public origin for CORS — must match the SITE_ADDRESS,
# e.g. https://jobs.example.com (or http://localhost for :80).
PUBLIC_ORIGIN=http://localhost
# Which image tag to pull from the registry (latest, v1.0.0, <sha> …).
IMAGE_TAG=latest
# Image coordinates (default: official GHCR images of this repo; adjust for forks).
# BACKEND_IMAGE=ghcr.io/<owner>/bewerbungsatze-backend
# FRONTEND_IMAGE=ghcr.io/<owner>/bewerbungsatze-frontend
# Host ports of the reverse proxy.
HTTP_PORT=80
HTTPS_PORT=443
